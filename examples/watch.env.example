# Rapture for Mac — watcher config (optional)
#
# Copy to ~/.config/rapture-mac/watch.env, edit, then re-run
# Scripts/install-claude-watch.sh to apply. Values are written into the launchd
# plist as EnvironmentVariables, so they survive reboots and reinstalls.
#
# Format: KEY=VALUE, one per line. Lines starting with # are ignored.

# Model for MEDIA notes (a URL or an attachment). These drive an extraction
# skill end-to-end, so they need a capable model. Default: sonnet.
RAPTURE_MEDIA_MODEL=sonnet

# Model for plain TEXT notes (reminders, journal, short tasks, emails).
# Cheap is fine here. Default: haiku.
RAPTURE_TEXT_MODEL=haiku

# Where Claude runs when processing a note (your agent / project repo).
# Default: $HOME. Uncomment and set to your workspace.
# RAPTURE_CLAUDE_WORKDIR=/Users/you/Source/your-repo

# Notes folder, if you don't rely on Rapture's sidecar-reported default.
# RAPTURE_NOTES_FOLDER=/Users/you/Documents/Rapture Notes

# Path to the claude binary. Default: /opt/homebrew/bin/claude.
# RAPTURE_CLAUDE_BIN=/opt/homebrew/bin/claude
